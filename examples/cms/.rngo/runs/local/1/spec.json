{
  "seed": 42,
  "start": "2024-01-01",
  "end": "2024-12-31",
  "effects": {
    "create-author": {
      "system": "db",
      "start": null,
      "end": null,
      "trigger": "1.0 / day",
      "format": {
        "type": null,
        "table": "authors"
      },
      "schema": {
        "type": "object",
        "properties": {
          "bio": {
            "pattern": ".{50,200}",
            "type": "string"
          },
          "created_at": {
            "path": [
              "trigger",
              "offset"
            ],
            "type": "context"
          },
          "email": {
            "pattern": "[a-z]{5,10}@[a-z]{4,8}\\.(com|net|org)",
            "type": "string"
          },
          "id": {
            "min": 1,
            "scale": 0,
            "step": 1,
            "type": "number"
          },
          "name": {
            "pattern": "[A-Z][a-z]{3,8} [A-Z][a-z]{4,10}",
            "type": "string"
          }
        }
      }
    },
    "create-post": {
      "system": "db",
      "start": null,
      "end": null,
      "trigger": "3.0 / day",
      "format": {
        "type": null,
        "table": "posts"
      },
      "schema": {
        "type": "object",
        "properties": {
          "author_id": {
            "expression": "author.id",
            "type": "function",
            "variables": {
              "author": {
                "effect": "create-author",
                "type": "reference"
              }
            }
          },
          "body": {
            "pattern": ".{200,500}",
            "type": "string"
          },
          "created_at": {
            "path": [
              "trigger",
              "offset"
            ],
            "type": "context"
          },
          "id": {
            "min": 1,
            "scale": 0,
            "step": 1,
            "type": "number"
          },
          "slug": {
            "pattern": "[a-z]{3,8}-[a-z]{3,8}-[a-z]{3,8}",
            "type": "string"
          },
          "status": {
            "options": [
              {
                "schema": {
                  "type": "constant",
                  "value": "published"
                },
                "weight": 3
              },
              {
                "schema": {
                  "type": "constant",
                  "value": "draft"
                },
                "weight": 1
              }
            ],
            "type": "select"
          },
          "title": {
            "pattern": "[A-Z][a-z]{3,10}( [a-z]{3,8}){2,5}",
            "type": "string"
          }
        }
      }
    }
  },
  "systems": {
    "db": {
      "format": {
        "type": "sql"
      },
      "import": {
        "type": "stream",
        "command": "psql $DATABASE_URL"
      }
    }
  }
}